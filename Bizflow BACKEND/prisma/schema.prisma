generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model aiInteraction {
  id         String   @id @default(cuid())
  businessId String
  prompt     String   @db.Text
  response   String   @db.Text
  feedback   Int?
  model      String   @default("gpt-3.5-turbo") @db.VarChar(50)
  createdAt  DateTime @default(now())
  business   business @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "AIInteraction_businessId_fkey")

  @@index([businessId, createdAt], map: "AIInteraction_businessId_createdAt_idx")
}

model appointment {
  id                 String               @id @default(cuid())
  businessId         String
  customerId         String?
  staffId            String?
  customerName       String               @db.VarChar(255)
  customerPhone      String               @db.VarChar(20)
  scheduledAt        DateTime
  duration           Int
  status             appointment_status   @default(SCHEDULED)
  notes              String?              @db.Text
  reminderSent       Boolean              @default(false)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  business           business             @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "Appointment_businessId_fkey")
  customer           customer?            @relation(fields: [customerId], references: [id], map: "Appointment_customerId_fkey")
  staff              user?                @relation(fields: [staffId], references: [id], map: "Appointment_staffId_fkey")
  appointmentservice appointmentservice[]

  @@index([businessId, scheduledAt], map: "Appointment_businessId_scheduledAt_idx")
  @@index([customerId], map: "Appointment_customerId_fkey")
  @@index([staffId, scheduledAt], map: "Appointment_staffId_scheduledAt_idx")
}

model appointmentservice {
  id            String      @id @default(cuid())
  appointmentId String
  serviceId     String
  appointment   appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade, map: "AppointmentService_appointmentId_fkey")
  service       service     @relation(fields: [serviceId], references: [id], map: "AppointmentService_serviceId_fkey")

  @@index([appointmentId], map: "AppointmentService_appointmentId_idx")
  @@index([serviceId], map: "AppointmentService_serviceId_fkey")
}

model auditlog {
  id         String   @id @default(cuid())
  businessId String
  userId     String?
  action     String   @db.VarChar(100)
  entity     String   @db.VarChar(50)
  entityId   String?  @db.VarChar(50)
  details    Json?
  ipAddress  String?  @db.VarChar(45)
  createdAt  DateTime @default(now())
  business   business @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "AuditLog_businessId_fkey")

  @@index([businessId, createdAt], map: "AuditLog_businessId_createdAt_idx")
}

model business {
  id              String            @id @default(cuid())
  name            String            @db.VarChar(255)
  type            business_type     @default(BARBERSHOP)
  phone           String            @db.VarChar(20)
  email           String?           @db.VarChar(255)
  address         String?           @db.VarChar(500)
  logoUrl         String?           @db.VarChar(500)
  mpesaTill       String?           @db.VarChar(20)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  aiInteraction   aiInteraction[]
  appointment     appointment[]
  auditlog        auditlog[]
  customer        customer[]
  queueentry      queueentry[]
  service         service[]
  transaction     transaction[]
  user            user[]
  whatsappmessage whatsappmessage[]

  @@index([id], map: "Business_id_idx")
}

model customer {
  id          String        @id @default(cuid())
  businessId  String
  name        String        @db.VarChar(255)
  phone       String        @db.VarChar(20)
  email       String?       @db.VarChar(255)
  notes       String?       @db.Text
  totalVisits Int           @default(0)
  lastVisit   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  appointments  appointment[]
  business      business      @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "Customer_businessId_fkey")
  queueEntries  queueentry[]
  transactions  transaction[]

  @@unique([phone, businessId], map: "Customer_phone_businessId_key")
  @@index([businessId], map: "Customer_businessId_idx")
  @@index([phone], map: "Customer_phone_idx")
}

model mpesacallback {
  id                String       @id @default(cuid())
  transactionId     String?      @unique(map: "MpesaCallback_transactionId_key")
  merchantRequestId String       @db.VarChar(100)
  checkoutRequestId String       @db.VarChar(100)
  resultCode        Int
  resultDesc        String       @db.VarChar(255)
  mpesaRef          String?      @db.VarChar(50)
  amount            Float?
  phoneNumber       String?      @db.VarChar(20)
  rawPayload        Json
  createdAt         DateTime     @default(now())
  transaction       transaction? @relation(fields: [transactionId], references: [id], map: "MpesaCallback_transactionId_fkey")

  @@index([checkoutRequestId], map: "MpesaCallback_checkoutRequestId_idx")
  @@index([createdAt], map: "MpesaCallback_createdAt_idx")
}

model queueentry {
  id            String            @id @default(cuid())
  businessId    String
  customerId    String?
  customerName  String            @db.VarChar(255)
  customerPhone String            @db.VarChar(20)
  position      Int
  status        queueentry_status @default(WAITING)
  notes         String?           @db.Text
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  business      business          @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "QueueEntry_businessId_fkey")
  customer      customer?         @relation(fields: [customerId], references: [id], map: "QueueEntry_customerId_fkey")
  services      queueservice[]

  @@index([businessId, status], map: "QueueEntry_businessId_status_idx")
  @@index([customerId], map: "QueueEntry_customerId_fkey")
  @@index([customerPhone], map: "QueueEntry_customerPhone_idx")
}

model queueservice {
  id           String     @id @default(cuid())
  queueEntryId String
  serviceId    String
  queueentry   queueentry @relation(fields: [queueEntryId], references: [id], onDelete: Cascade, map: "QueueService_queueEntryId_fkey")
  service      service    @relation(fields: [serviceId], references: [id], map: "QueueService_serviceId_fkey")

  @@index([queueEntryId], map: "QueueService_queueEntryId_idx")
  @@index([serviceId], map: "QueueService_serviceId_fkey")
}

model service {
  id                 String               @id @default(cuid())
  businessId         String
  name               String               @db.VarChar(255)
  price              Float
  duration           Int
  isActive           Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  appointments       appointmentservice[]
  queueEntries       queueservice[]
  business           business             @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "Service_businessId_fkey")
  transactions       transactionservice[]

  @@index([businessId], map: "Service_businessId_idx")
}

model staffschedule {
  id        String   @id @default(cuid())
  userId    String
  dayOfWeek Int
  isOff     Boolean  @default(false)
  startTime String?  @db.VarChar(5)
  endTime   String?  @db.VarChar(5)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "StaffSchedule_userId_fkey")

  @@unique([userId, dayOfWeek], map: "StaffSchedule_userId_dayOfWeek_key")
  @@index([userId], map: "StaffSchedule_userId_idx")
}

model transaction {
  id                 String                    @id @default(cuid())
  businessId         String
  customerId         String?
  staffId            String?
  paymentMethod      transaction_paymentMethod
  status             transaction_status        @default(PENDING)
  totalAmount        Float
  mpesaRef           String?                   @db.VarChar(50)
  mpesaPhone         String?                   @db.VarChar(20)
  receiptNumber      String                    @unique(map: "Transaction_receiptNumber_key") @db.VarChar(50)
  notes              String?                   @db.Text
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  mpesacallback      mpesacallback?
  business           business                  @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "Transaction_businessId_fkey")
  customer           customer?                 @relation(fields: [customerId], references: [id], map: "Transaction_customerId_fkey")
  user               user?                     @relation(fields: [staffId], references: [id], map: "Transaction_staffId_fkey")
  services           transactionservice[]

  @@index([businessId], map: "Transaction_businessId_idx")
  @@index([createdAt], map: "Transaction_createdAt_idx")
  @@index([customerId], map: "Transaction_customerId_idx")
  @@index([staffId], map: "Transaction_staffId_fkey")
}

model transactionservice {
  id            String      @id @default(cuid())
  transactionId String
  serviceId     String
  price         Float
  service       service     @relation(fields: [serviceId], references: [id], map: "TransactionService_serviceId_fkey")
  transaction   transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade, map: "TransactionService_transactionId_fkey")

  @@index([serviceId], map: "TransactionService_serviceId_fkey")
  @@index([transactionId], map: "TransactionService_transactionId_idx")
}

model user {
  id            String          @id @default(cuid())
  businessId    String
  name          String          @db.VarChar(255)
  phone         String          @db.VarChar(20)
  email         String?         @db.VarChar(255)
  passwordHash  String          @db.VarChar(255)
  role          user_role       @default(STAFF)
  isActive      Boolean         @default(true)
  refreshToken  String?         @db.Text
  resetOtp      String?         @db.VarChar(10)
  resetOtpExp   DateTime?
  commission    Float           @default(0)
  profilePhoto  String?         @db.VarChar(500)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  appointments       appointment[]
  schedules          staffschedule[]
  transactions       transaction[]
  business      business        @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "User_businessId_fkey")

  @@unique([phone, businessId], map: "User_phone_businessId_key")
  @@index([businessId], map: "User_businessId_idx")
  @@index([phone], map: "User_phone_idx")
}

model whatsappmessage {
  id         String   @id @default(cuid())
  businessId String
  phone      String   @db.VarChar(20)
  messageId  String?  @db.VarChar(100)
  direction  String   @db.VarChar(10)
  content    String   @db.Text
  status     String?  @db.VarChar(20)
  createdAt  DateTime @default(now())
  business   business @relation(fields: [businessId], references: [id], onDelete: Cascade, map: "WhatsAppMessage_businessId_fkey")

  @@index([businessId, createdAt], map: "WhatsAppMessage_businessId_createdAt_idx")
  @@index([phone], map: "WhatsAppMessage_phone_idx")
}

enum business_type {
  BARBERSHOP
  SALON
  GYM
  SPA
  OTHER
}

enum transaction_paymentMethod {
  MPESA
  CASH
}

enum transaction_status {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum queueentry_status {
  WAITING
  SERVING
  COMPLETED
  SKIPPED
}

enum user_role {
  OWNER
  MANAGER
  STAFF
  VIEWER
}

enum appointment_status {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}
